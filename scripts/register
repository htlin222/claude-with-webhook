#!/usr/bin/env bash
set -euo pipefail

# Register the current git repo with the claude-webhook server.
# Usage: cd /path/to/repo && ~/.claude-webhook/register

SERVER_DIR="$(cd "$(dirname "$0")" && pwd)"

# Parse flags.
FORCE=false
for arg in "$@"; do
  case "$arg" in
    --force) FORCE=true ;;
  esac
done

# Must be in a git repo.
if ! git rev-parse --is-inside-work-tree &>/dev/null; then
  echo "ERROR: Not inside a git repository."
  exit 1
fi

REPO_DIR=$(git rev-parse --show-toplevel)

# Check prerequisites.
for cmd in gh jq curl; do
  if ! command -v "$cmd" &>/dev/null; then
    echo "ERROR: Missing required tool: $cmd"
    exit 1
  fi
done

# Detect GitHub repo name.
GH_REPO=$(gh repo view --json nameWithOwner --jq '.nameWithOwner' 2>/dev/null || true)
if [ -z "$GH_REPO" ]; then
  echo "ERROR: Could not detect GitHub repo. Make sure 'gh' is authenticated."
  exit 1
fi

# Load .env for webhook secret and port.
if [ ! -f "$SERVER_DIR/.env" ]; then
  echo "ERROR: $SERVER_DIR/.env not found. Run 'make install' in the claude-with-webhook repo first."
  exit 1
fi
set -a
source "$SERVER_DIR/.env"
set +a

# --- Register repo in repos.conf ---
REPOS_CONF="$SERVER_DIR/repos.conf"
touch "$REPOS_CONF"

if grep -q "^${GH_REPO}=" "$REPOS_CONF" 2>/dev/null; then
  sed -i.bak "s|^${GH_REPO}=.*|${GH_REPO}=${REPO_DIR}|" "$REPOS_CONF"
  rm -f "$REPOS_CONF.bak"
  echo "Updated: $GH_REPO → $REPO_DIR"
else
  echo "${GH_REPO}=${REPO_DIR}" >> "$REPOS_CONF"
  echo "Registered: $GH_REPO → $REPO_DIR"
fi

# Create worktrees dir + .gitignore entry.
mkdir -p "$REPO_DIR/worktrees"
if ! grep -qx 'worktrees/' "$REPO_DIR/.gitignore" 2>/dev/null; then
  echo 'worktrees/' >> "$REPO_DIR/.gitignore"
  echo "Added worktrees/ to .gitignore"
fi

# Signal running server to reload.
if pkill -HUP -f claude-webhook-server 2>/dev/null; then
  echo "Server reloaded repos.conf."
else
  echo "Server not running (will pick up on next start)."
fi

# --- Ensure gh has admin:repo_hook scope ---
SCOPES=$(gh auth status 2>&1 || true)
if ! echo "$SCOPES" | grep -q "admin:repo_hook"; then
  echo "Requesting admin:repo_hook scope..."
  gh auth refresh -h github.com -s admin:repo_hook
fi

# --- Tunnel setup ---
PORT="${PORT:-8080}"
TUNNEL_FILE="$SERVER_DIR/.tunnel"

if command -v tailscale &>/dev/null; then
  TUNNEL_TYPE="tailscale"
  TS_HOSTNAME=$(tailscale status --json 2>/dev/null | jq -r '.Self.DNSName' | sed 's/\.$//')

  FUNNEL_STATUS=$(tailscale funnel status 2>&1 || true)
  if ! echo "$FUNNEL_STATUS" | grep -q "proxy http://127.0.0.1:${PORT}"; then
    echo "Setting up Tailscale Funnel on port $PORT..."
    tailscale funnel --bg "$PORT"
  fi

  TUNNEL_URL="https://${TS_HOSTNAME}"

elif command -v ngrok &>/dev/null; then
  TUNNEL_TYPE="ngrok"

  # Kill any existing ngrok process on this port.
  if curl -s --max-time 2 http://127.0.0.1:4040/api/tunnels &>/dev/null; then
    echo "ngrok already running, reusing existing tunnel..."
  else
    echo "Starting ngrok tunnel on port $PORT..."
    ngrok http "$PORT" --log=stdout > /dev/null 2>&1 &

    # Wait for ngrok to be ready (up to 10 seconds).
    for _ in $(seq 1 20); do
      if curl -s --max-time 1 http://127.0.0.1:4040/api/tunnels &>/dev/null; then
        break
      fi
      sleep 0.5
    done

    if ! curl -s --max-time 2 http://127.0.0.1:4040/api/tunnels &>/dev/null; then
      echo "ERROR: ngrok failed to start. Check your ngrok configuration."
      exit 1
    fi
  fi

  NGROK_URL=$(curl -s http://127.0.0.1:4040/api/tunnels | jq -r '.tunnels[] | select(.proto == "https") | .public_url' | head -1)
  if [ -z "$NGROK_URL" ]; then
    echo "ERROR: Could not get ngrok public URL."
    exit 1
  fi

  TUNNEL_URL="$NGROK_URL"

elif command -v zrok &>/dev/null; then
  TUNNEL_TYPE="zrok"

  # Check if zrok is already sharing on this port.
  ZROK_URL=$(zrok overview 2>/dev/null | jq -r '.[] | select(.share_mode == "public") | .frontend_endpoint' 2>/dev/null | head -1 || echo "")

  if [ -n "$ZROK_URL" ]; then
    echo "zrok already sharing, reusing existing tunnel..."
  else
    echo "Starting zrok public share on port $PORT..."
    zrok share public "http://localhost:${PORT}" --headless > /tmp/zrok-share.log 2>&1 &

    # Wait for zrok to be ready (up to 15 seconds).
    for _ in $(seq 1 30); do
      ZROK_URL=$(grep -oP 'https://[a-z0-9]+\.share\.zrok\.io' /tmp/zrok-share.log 2>/dev/null | head -1 || echo "")
      if [ -n "$ZROK_URL" ]; then
        break
      fi
      sleep 0.5
    done

    if [ -z "$ZROK_URL" ]; then
      echo "ERROR: zrok failed to start. Check your zrok configuration (run 'zrok invite' and 'zrok enable' first)."
      exit 1
    fi
  fi

  TUNNEL_URL="$ZROK_URL"

else
  echo "ERROR: No tunnel tool found. Install tailscale, ngrok, or zrok."
  echo "  Tailscale: https://tailscale.com/download"
  echo "  ngrok:     https://ngrok.com/download"
  echo "  zrok:      https://zrok.io"
  exit 1
fi

echo "$TUNNEL_TYPE" > "$TUNNEL_FILE"
echo "Tunnel: $TUNNEL_TYPE → $TUNNEL_URL"

# --- Create/update GitHub webhook ---
WEBHOOK_URL="${TUNNEL_URL}/${GH_REPO}/webhook"

# Detect existing webhooks from other servers to prevent duplicate processing.
ALL_HOOKS=$(gh api "repos/$GH_REPO/hooks" --jq '.[].config.url' 2>/dev/null || true)
OTHER_HOOKS=$(echo "$ALL_HOOKS" | grep "/webhook$" | grep -v "^${TUNNEL_URL}/" || true)

if [ -n "$OTHER_HOOKS" ]; then
  echo "⚠️  WARNING: This repo already has webhook(s) from other server(s):"
  echo "$OTHER_HOOKS"
  echo ""
  echo "Multiple servers on the same repo will cause duplicate plans and conflicting PRs."

  if [ "$FORCE" = true ]; then
    echo "  --force: removing existing webhook(s)..."
    CONFIRM="y"
  else
    read -rp "Replace existing webhook(s) and continue? [y/N] " CONFIRM
  fi

  if [[ "$CONFIRM" =~ ^[Yy]$ ]]; then
    for hook_url in $OTHER_HOOKS; do
      OLD_ID=$(gh api "repos/$GH_REPO/hooks" --jq ".[] | select(.config.url == \"$hook_url\") | .id")
      gh api "repos/$GH_REPO/hooks/$OLD_ID" --method DELETE --silent
      echo "Removed old webhook: $hook_url"
    done
  else
    echo "Aborted. Remove the other webhook manually or use --force."
    exit 1
  fi
fi

EXISTING_HOOK=$(gh api "repos/$GH_REPO/hooks" --jq ".[] | select(.config.url == \"$WEBHOOK_URL\") | .id" 2>/dev/null || true)

if [ -n "$EXISTING_HOOK" ]; then
  gh api "repos/$GH_REPO/hooks/$EXISTING_HOOK" --method PATCH \
    -f "config[url]=$WEBHOOK_URL" \
    -f 'config[content_type]=json' \
    -f "config[secret]=$GITHUB_WEBHOOK_SECRET" \
    -f 'events[]=issues' \
    -f 'events[]=issue_comment' \
    -F active=true --silent
  echo "Webhook updated."
else
  gh api "repos/$GH_REPO/hooks" --method POST \
    -f name=web \
    -f "config[url]=$WEBHOOK_URL" \
    -f 'config[content_type]=json' \
    -f "config[secret]=$GITHUB_WEBHOOK_SECRET" \
    -f 'events[]=issues' \
    -f 'events[]=issue_comment' \
    -F active=true --silent
  echo "Webhook created."
fi

echo
echo "✓ $GH_REPO registered"
echo "  Webhook: $WEBHOOK_URL"
echo "  Local:   $REPO_DIR"
echo
